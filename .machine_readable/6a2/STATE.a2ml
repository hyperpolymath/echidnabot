# STATE.a2ml — Echidnabot project state
[metadata]
project = "echidnabot"
version = "0.1.0"
last-updated = "2026-04-24"
status = "active"
session = "7b double-loop actuation (Opus side), scm→a2ml migrated 2026-04-11"

[project-context]
name = "Echidnabot"
purpose = """
Tier-1 Verifier bot in the gitbot-fleet. Bridges webhook events from
GitHub/GitLab/Bitbucket to the ECHIDNA proof engine, schedules verification
jobs with isolation, and reports findings back to the fleet. Exposes
double-loop feedback: reranks ECHIDNA's ML suggestions by local tactic
history, feeds successful proofs into echidna's retrain corpus.
"""
completion-percentage = 80

[position]
phase = "implementation"
maturity = "beta"

# ═══════════════════════════════════════════════════════════════════════════════
# CRG (Critical Reception Grade) advancement — D→C→B
# Per memory rule: B-grade requires [external-targets]≥6, [issues-fed-back],
# [field-signal] populated.
# ═══════════════════════════════════════════════════════════════════════════════

[external-targets]
[[external-targets.target]]
name = "gitbot-fleet"
relationship = "fleet-member"
contract = "Tier-1 Verifier per fleet topology; coordinates with rhodibot/panicbot/sustainabot via shared-context"
discovered = "ECOSYSTEM.a2ml + bot directives in target repos"

[[external-targets.target]]
name = "echidna (upstream proof engine)"
relationship = "consumer-of"
contract = "REST/GraphQL via dispatcher/echidna_client.rs; 12 of 113 ProverKind variants currently surfaced"
discovered = "src/dispatcher/echidna_client.rs"

[[external-targets.target]]
name = "AI assistants (Claude Desktop / Claude Code)"
relationship = "consumer-via-mcp"
contract = "JSON-RPC over stdio via echidnabot-mcp bin (4 tools: suggest_tactics, record_tactic_outcome, list_outcome_history, corpus_refresh)"
