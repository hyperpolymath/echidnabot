# ─── Panic-attack sweep 2026-04-25 ─────────────────────────────────────
[panic-attack-sweep]
date = "2026-04-25"
last-result = "pass-with-classified-false-positives"
findings = """
echidnabot:
  - 2 Critical (ProofDrift on proofs/coq/admitted_stub.v + proofs/lean/sorry_stub.lean)
    → INTENTIONAL DOGFOOD FIXTURES from commit ec25aae. Designed to
      exercise the bot's failure path. False positives — panic-attack
      lacks fixture-exclusion; structural-first per memory rule but
      no config option exists. Not chasing.
  - 1 Low (MutationGap — no cargo-mutants config). Add later if mutation
    testing becomes an estate-wide rule.
  - Statistics: 17 unwrap_calls, 0 panic_sites, 15 unsafe_blocks (all
    legitimate FFI), 14 threading constructs.

vcl-ut:
  - 2 Critical (UnboundedAllocation on src/interface/{fmt,lint}/src/main.rs)
    → fs::read_to_string of operator-supplied file. CLI tools, trusted
      input. False positive in this context (no untrusted-input boundary).
  - 1 Medium (InsecureProtocol on echidna-client lib.rs)
    → http://127.0.0.1:8000 as the default echidna URL. Localhost; HTTPS
      isn't expected for default local-dev path. False positive.
  - 1 Low (MutationGap).

boj-server cartridges/echidna-llm-mcp:
  - 1 High (UnsafeCode on ffi/cartridge_shim.zig)
    → 1 unsafe @ptrCast in the FFI shim. Per memory rule "panic-attack
      unsafe_blocks conflates banned partial casts with legitimate FFI
      try/catch — classify each hit." This one is legitimate FFI surface.
  - 1 Medium (InsecureProtocol on mod.js)
    → localhost echidna URL. False positive (same as vcl-ut).

echidna:
  - SCAN TIMED OUT at 180s (repo too large for a single assail run).
    Defer to a chunked/per-subdir invocation in a future sweep.

Real critical findings: 0. All flagged criticals are classified
false-positives or operator-trusted-input patterns.
"""

# ─── Task E: ProverKind Enum→Slug Migration (2026-04-25) ─────────────────────────
[session-2026-04-25-task-e]
title       = "ProverKind enum→slug migration: 12-variant → dynamic 113-prover support"
phase       = "implementation"
completion  = 100
status      = "done — 0 compilation errors; 132 lib tests + 8 integration tests pass (2026-04-26)"
date        = "2026-04-25"
session-key = "echidnabot-task-e"

[session-2026-04-25-task-e.context]
objective   = """
Migrate echidnabot from 12-variant ProverKind enum to a ProverSlug(String) struct
that dynamically supports all 113 echidna provers at runtime. This unblocks
Advisor/Consultant/Regulator bot modes, which require access to the full prover
surface that echidna provides.
"""

epic        = "Echidna Reorganisation + Roadmap + A2ML Conformance (2026-04-25 plan)"
upstream    = "ADR-CART-003 (2026-04-25) in dispatcher/mod.rs; ProverSlug replaces enum"

[session-2026-04-25-task-e.migration-strategy]
approach = """
1. Replace 12-variant enum ProverKind with struct ProverSlug(String)
2. Add type alias: pub type ProverKind = ProverSlug (backwards compatibility)
3. Update CLASSIC_PROVERS constant to map (slug, display_name) tuples
4. Implement methods: new(), as_str(), from_extension(), display_name(), tier(),
   file_extensions(), classic_all(), all()
5. Convert 224+ enum-variant match patterns to .as_str() string comparisons
6. Update function signatures: owned ProverKind → &ProverKind references
7. Handle struct fields: avoid lifetime specifiers by owning ProverKind, use .clone()
   at construction time (trade clone cost for simpler lifetime annotations)
"""

affected-modules = [
  "src/dispatcher/mod.rs (core struct + methods)",
  "src/store/sqlite.rs (parse_prover → dynamic ProverKind::new())",
  "src/api/graphql.rs (identity map_prover_kind, reference passing)",
  "src/dispatcher/echidna_client.rs (function signatures → &ProverKind)",
  "src/executor/container.rs (prover_to_env_name, prover_extension, prover_command)",
  "src/trust/axiom_tracker.rs (scan method signature)",
  "src/trust/confidence.rs (struct field ownership, .clone() at construction)",
  "src/trust/solver_integrity.rs (struct field: owned ProverKind)",
  "src/webhooks.rs (estimated, parameter passing)",
  "src/feedback/reranker.rs (estimated, parameter passing)",
]

[session-2026-04-25-task-e.commits]
commit-1 = """
7052195 feat(Task E): Begin ProverKind enum→slug migration for 113-prover support
  - Replaced 12-variant ProverKind enum with struct ProverSlug(String)
  - Added type alias pub type ProverKind = ProverSlug for backwards compatibility
  - Updated CLASSIC_PROVERS constant (12 provers with display names and extensions)
  - Implemented core methods: new(), as_str(), from_extension(), display_name()
  - Implemented tier(), file_extensions(), classic_all(), all()
  - Updated src/store/sqlite.rs parse_prover(): enum patterns → ProverKind::new()
  - First pass error reduction: 136 → 136 errors (enum variant patterns remain)
"""

commit-2 = """
1b465ba refactor(Task E): Continue ProverKind→ProverSlug migration integration
  - Converted match statements: enum patterns → .as_str() string comparisons
  - Updated function signatures: owned → &ProverKind references throughout
  - Replaced struct fields: &ProverKind → owned ProverKind with .clone() calls
  - Changed .copied() → .cloned() for non-Copy iterator handling
  - Updated src/api/graphql.rs: identity maps for map_prover_kind/map_prover_kind_to_core
  - Updated src/dispatcher/echidna_client.rs: verify_proof, suggest_tactics, prover_status
  - Updated src/executor/container.rs: prover_to_env_name, prover_extension, prover_command
  - Updated src/trust/{axiom_tracker,confidence,solver_integrity}.rs
  - Second pass error reduction: 136 → 26 errors (systematic parameter-type integration remains)
"""

