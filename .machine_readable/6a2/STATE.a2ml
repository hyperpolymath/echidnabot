[[external-targets.target]]
name = "boj-server / cartridges / echidna-llm-mcp"
relationship = "future-absorption"
contract = "When BoJ loader supports double-loop feedback protocol, echidnabot-mcp folds into the BoJ cartridge per ADR-001 sunset clause"
