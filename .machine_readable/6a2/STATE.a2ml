# STATE.a2ml — Echidnabot project state
[metadata]
project = "echidnabot"
version = "0.1.0"
last-updated = "2026-04-24"
status = "active"
session = "7b double-loop actuation (Opus side), scm→a2ml migrated 2026-04-11"

[project-context]
name = "Echidnabot"
purpose = """
Tier-1 Verifier bot in the gitbot-fleet. Bridges webhook events from
GitHub/GitLab/Bitbucket to the ECHIDNA proof engine, schedules verification
jobs with isolation, and reports findings back to the fleet. Exposes
double-loop feedback: reranks ECHIDNA's ML suggestions by local tactic
history, feeds successful proofs into echidna's retrain corpus.
"""
completion-percentage = 80

[position]
phase = "implementation"
maturity = "beta"

[route-to-mvp]
milestones = [
  "7a: Sonnet — wire bot modes (Advisor/Consultant/Regulator) into webhook handlers + container executor",
  "7b: Opus — double-loop actuation (this session)",
  "integration: 7a + 7b seam test via dogfood proofs/",
]

[blockers-and-issues]
issues = [
  "7b-3 schema gap: CorpusDelta emits delta_YYYY-MM-DD.jsonl; echidna merge_corpus.jl expects proof_states_*.jsonl in a hardcoded whitelist. Successful deltas not yet auto-ingested. Coordination ticket with Session A.",
  "BoJ server unreachable on this workstation (V adapter removed, Zig rewrite empty). Native MCP shipped as temporary documented exception — see ADR-001 in META.a2ml.",
]

[known-drift]
# Standing structural issues that are not bugs but need eventual cleanup.
# Each entry MUST name the drift, its blast radius, and its resolution path.

[[known-drift.entry]]
id             = "DRIFT-001"
name           = "dual-truth monorepo + standalone"
description    = """
echidnabot is registered in the parent echidna repo's .gitmodules but its
contents are checked in as regular files (not a live submodule). This creates
two sources of truth: changes to .machine_readable/, src/, etc. must land in
both this standalone repo and the monorepo copy at
echidna/echidnabot/ — otherwise the two diverge silently.

Pattern catalogued in memory: project_gitbot_fleet_dual_truth_pattern.md.
"""
blast-radius   = "all edits to .machine_readable/, src/, docs/ must be mirrored"
detection      = "git diff against monorepo copy; CI could be added to fail on divergence"
resolution     = "either (a) promote to real submodule with .gitmodules resolving, or (b) delete the .gitmodules entry and treat as pure monorepo subdir. Pick one, not both."
status         = "acknowledged, no scheduled fix"
discovered     = "2026-04-24 (by parallel Claude session during Package 7 sweep)"

[critical-next-actions]
actions = [
  "7a mode wiring (Sonnet): process_job pipeline + Advisor/Consultant PR comments + Regulator merge-block",
  "Session A + 7b-3 schema bridge: either (a) echidnabot emits echidna-schema rows for successes, or (b) merge_corpus.jl learns to consume delta files",
  "Close BoJ Zig adapter so echidnabot-mcp can be folded into a BoJ cartridge and retired",
]

[maintenance-status]
